From 94dce72f3ce7a79c9b3cfb26496e7da160bd7afb Mon Sep 17 00:00:00 2001
From: Subu Dwevedi <messigoatcr7nop@gmail.com>
Date: Mon, 22 Dec 2025 03:20:30 +0530
Subject: [PATCH 11/15] mfd/macsmc_core: add bool to diffrenciate M-series with
 Intel

Signed-off-by: Subu Dwevedi <messigoatcr7nop@gmail.com>
---
 drivers/mfd/macsmc-core.c  | 3 +++
 include/linux/mfd/macsmc.h | 2 ++
 2 files changed, 5 insertions(+)

diff --git a/drivers/mfd/macsmc-core.c b/drivers/mfd/macsmc-core.c
index 5331cfe9a876..f0920bef7a8b 100644
--- a/drivers/mfd/macsmc-core.c
+++ b/drivers/mfd/macsmc-core.c
@@ -105,6 +105,9 @@ int apple_smc_probe(struct device *dev, const struct apple_smc_backend_ops *ops,
 	ret = devm_add_action_or_reset(dev, apple_smc_disable_notifications, smc);
 	if (ret < 0)
 		return ret;
+#else
+	//Also enable the acpi bool if not M-series
+	smc->is_acpi = true;
 #endif
 
 	ret = apple_smc_read_u32(smc, SMC_KEY(#KEY), &count);
diff --git a/include/linux/mfd/macsmc.h b/include/linux/mfd/macsmc.h
index 0ca444f31fb1..83e1a0a9a057 100644
--- a/include/linux/mfd/macsmc.h
+++ b/include/linux/mfd/macsmc.h
@@ -117,6 +117,8 @@ struct apple_smc {
 	void *be_cookie;
 	const struct apple_smc_backend_ops *be;
 
+	bool is_acpi;
+
 	struct mutex mutex;
 	spinlock_t lock;
 };
-- 
