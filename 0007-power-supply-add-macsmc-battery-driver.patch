index 000000000000..3b72b89b1a74
--- /dev/null
+++ b/drivers/power/supply/macsmc-battery.c
@@ -0,0 +1,234 @@
+// SPDX-License-Identifier: GPL-2.0-only OR MIT
+/*
+ * Apple SMC Battery controller for x86 Macs
+ * Subu Dwevedi <messigoatcr7nop@gmail.com>
+ */
+#include <linux/mfd/macsmc.h>
+#include <linux/platform_device.h>
+#include <linux/power_supply.h>
+#include <linux/swab.h>
+
+static enum power_supply_property macsmc_battery_charge_props[] = {
+	POWER_SUPPLY_PROP_CAPACITY,
+	POWER_SUPPLY_PROP_CHARGE_CONTROL_END_THRESHOLD,
+	POWER_SUPPLY_PROP_CHARGE_FULL,
+	POWER_SUPPLY_PROP_CHARGE_NOW,
+	POWER_SUPPLY_PROP_CONSTANT_CHARGE_CURRENT_MAX,
+	POWER_SUPPLY_PROP_CONSTANT_CHARGE_VOLTAGE,
+	POWER_SUPPLY_PROP_CURRENT_NOW,
+	POWER_SUPPLY_PROP_CYCLE_COUNT,
+	POWER_SUPPLY_PROP_HEALTH,
+	POWER_SUPPLY_PROP_PRESENT,
+	POWER_SUPPLY_PROP_STATUS,
+	POWER_SUPPLY_PROP_TECHNOLOGY,
+	POWER_SUPPLY_PROP_TIME_TO_FULL_NOW,
+	POWER_SUPPLY_PROP_VOLTAGE_NOW,
+};
+
+
+static int macsmc_battery_get_property(struct power_supply *psy,
+	enum power_supply_property psp, union power_supply_propval *val)
+{
+	struct apple_smc *smc = power_supply_get_drvdata(psy);
+	int ret;
+
+	u8 u8_buf;
+	u16 u16_buf;
+	s16 s16_buf;
+	bool bool_buf;
+
+	switch (psp) {
+	case POWER_SUPPLY_PROP_STATUS:
+		ret = apple_smc_read_u16(smc, SMC_KEY(B0TF), &u16_buf);
+		if (ret < 0)
+			return ret;
+
+		if (u16_buf == 0xFFFF) {
+			val->intval = POWER_SUPPLY_STATUS_NOT_CHARGING;
+			break;
+		}
+		ret = apple_smc_read_u16(smc, SMC_KEY(BRSC), &u16_buf);
+		if (ret < 0)
+			return ret;
+
+		if (swab16(u16_buf) == 100)
+			val->intval = POWER_SUPPLY_STATUS_FULL;
+		else
+			val->intval = POWER_SUPPLY_STATUS_CHARGING;
+
+		break;
+
+	case POWER_SUPPLY_PROP_VOLTAGE_NOW:
+		ret = apple_smc_read_u16(smc, SMC_KEY(B0AV), &u16_buf);
+		if (ret < 0)
+			return ret;
+		val->intval = swab16(u16_buf) * 1000;
+		break;
+
+	case POWER_SUPPLY_PROP_CURRENT_NOW:
+		ret = apple_smc_read_s16(smc, SMC_KEY(B0AC), &s16_buf);
+		if (ret < 0)
+			return ret;
+		val->intval = swab16(u16_buf) * 1000;
+		break;
+
+	case POWER_SUPPLY_PROP_CHARGE_FULL:
+		ret = apple_smc_read_u16(smc, SMC_KEY(B0FC), &u16_buf);
+		if (ret < 0)
+			return ret;
+		val->intval = swab16(u16_buf) * 1000;
+		break;
+
+	case POWER_SUPPLY_PROP_CHARGE_NOW:
+		ret = apple_smc_read_u16(smc, SMC_KEY(B0RM), &u16_buf);
+		if (ret < 0)
+			return ret;
+		val->intval = swab16(u16_buf) * 1000;
+		break;
+
+	case POWER_SUPPLY_PROP_CAPACITY:
+		ret = apple_smc_read_u16(smc, SMC_KEY(BRSC), &u16_buf);
+		if (ret < 0)
+			return ret;
+		val->intval = swab16(u16_buf);
+		break;
+
+	case POWER_SUPPLY_PROP_CYCLE_COUNT:
+		ret = apple_smc_read_u16(smc, SMC_KEY(B0CT), &u16_buf);
+		if (ret < 0)
+			return ret;
+		val->intval = swab16(u16_buf);
+		break;
+
+	case POWER_SUPPLY_PROP_PRESENT:
+		ret = apple_smc_read_flag(smc, SMC_KEY(BBIN), &bool_buf);
+		if (ret < 0)
+			return ret;
+
+		val->intval = bool_buf;
+		break;
+
+	case POWER_SUPPLY_PROP_HEALTH:
+		ret = apple_smc_read_flag(smc, SMC_KEY(BBAD), &bool_buf);
+		if (ret < 0)
+			return ret;
+
+		val->intval = bool_buf ? POWER_SUPPLY_HEALTH_DEAD :
+			POWER_SUPPLY_HEALTH_GOOD;
+
+		break;
+
+	case POWER_SUPPLY_PROP_TECHNOLOGY:
+		val->intval = POWER_SUPPLY_TECHNOLOGY_LION;
+		break;
+
+	case POWER_SUPPLY_PROP_TIME_TO_FULL_NOW:
+		ret = apple_smc_read_u16(smc, SMC_KEY(B0TF), &u16_buf);
+		if (ret < 0)
+			return ret;
+
+		val->intval = (u16_buf == 0xffff) ? 0 : swab16(u16_buf) * 60;
+		break;
+
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_CURRENT_MAX:
+		ret = apple_smc_read_u16(smc, SMC_KEY(B0RI), &u16_buf);
+		if (ret < 0)
+			return ret;
+
+		val->intval = swab16(u16_buf) * 1000;
+		break;
+
+	case POWER_SUPPLY_PROP_CONSTANT_CHARGE_VOLTAGE:
+		ret = apple_smc_read_u16(smc, SMC_KEY(B0RV), &u16_buf);
+		if (ret < 0)
+			return ret;
+
+		val->intval = swab16(u16_buf) * 1000;
+		break;
+
+	case POWER_SUPPLY_PROP_CHARGE_CONTROL_END_THRESHOLD:
+		ret = apple_smc_read_u8(smc, SMC_KEY(BCLM), &u8_buf);
+		if (ret < 0)
+			return ret;
+		val->intval = u8_buf;
+		break;
+	default:
+		return -EINVAL;
+	}
+	return 0;
+}
+
+static int macsmc_battery_set_property(struct power_supply *psy,
+	enum power_supply_property psp, const union power_supply_propval *val)
+{
+	struct apple_smc *smc = power_supply_get_drvdata(psy);
+	int ret;
+
+	if (val->intval > 100 || val->intval < 1)
+		return -EINVAL;
+
+	switch (psp) {
+	case POWER_SUPPLY_PROP_CHARGE_CONTROL_END_THRESHOLD:
+		ret = apple_smc_write_u8(smc, SMC_KEY(BCLM), (u8) val->intval);
+		break;
+	default:
+		return -EINVAL;
+	}
+	if (ret < 0)
+		return ret;
+
+	return 0;
+}
+
+static int macsmc_battery_is_writeable(struct power_supply *psy,
+		enum power_supply_property psp)
+{
+	if (psp == POWER_SUPPLY_PROP_CHARGE_CONTROL_END_THRESHOLD)
+		return 1;
+
+	return 0;
+}
+
+static const struct power_supply_desc macsmc_battery_desc = {
+	.properties = macsmc_battery_charge_props,
+	.num_properties = ARRAY_SIZE(macsmc_battery_charge_props),
+	.get_property = macsmc_battery_get_property,
+	.set_property = macsmc_battery_set_property,
+	.property_is_writeable = macsmc_battery_is_writeable,
+	.name = "macsmc-battery",
+	.type = POWER_SUPPLY_TYPE_BATTERY
+};
+
+static int macsmc_battery_probe(struct platform_device *pdev)
+{
+	struct power_supply_config psy_cfg;
+	struct power_supply *psy;
+	struct apple_smc *smc = dev_get_drvdata(pdev->dev.parent);
+	int ret;
+	bool buf;
+
+	if (!smc)
+		return -ENODEV;
+
+	ret = apple_smc_read_flag(smc, SMC_KEY(BBIN), &buf);
+	if (ret < 0 || !buf)
+		return -ENODEV;
+
+	psy_cfg.drv_data = smc;
+	psy = devm_power_supply_register(&pdev->dev, &macsmc_battery_desc, &psy_cfg);
+
+	return PTR_ERR_OR_ZERO(psy);
+}
+
+static struct platform_driver macsmc_battery_driver = {
+	.probe = macsmc_battery_probe,
+	.driver = {
+		.name = "macsmc-battery",
+	}
+};
+module_platform_driver(macsmc_battery_driver);
+
+MODULE_ALIAS("platform:macsmc-battery");
+MODULE_AUTHOR("Subu Dwevedi <messigoatcr7nop@gmail.com>");
+MODULE_LICENSE("Dual MIT/GPL");
+MODULE_DESCRIPTION("Apple SMC Battery controller for x86 Macs");
