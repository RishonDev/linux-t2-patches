@@ -651,7 +678,7 @@ static int macsmc_hwmon_create_fan(struct device *dev, struct apple_smc *smc,
 	}
 
 	if (!of_property_read_string(fan_node, "apple,fan-maximum", &max)) {
-		ret = macsmc_hwmon_parse_key(dev, smc, &fan->max, max);
+		ret = macsmc_hwmon_parse_key(dev, smc, &fan->max, _SMC_KEY(max));
