index 000000000000..eb727bf18e0a
--- /dev/null
+++ b/drivers/video/backlight/macsmc-bl.c
@@ -0,0 +1,92 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * macsmc-bl - LED Backlight driver for Intel-macs using macsmc
+ *
+ * Copyright (C) Subu Dwevedi <messigoatcr7nop@gmail.com>
+ */
+
+#include <linux/backlight.h>
+#include <linux/mfd/macsmc.h>
+#include <linux/platform_device.h>
+
+#define BACKLIGHT_BRIGHTNESS_KEY SMC_KEY(LKSB)
+
+struct macsmc_bl {
+	struct apple_smc *smc;
+	u16 brightness;
+};
+
+static int macsmc_bl_update_status(struct backlight_device *bl)
+{
+	struct macsmc_bl *smc_bl = bl_get_data(bl);
+	int ret;
+
+	smc_bl->brightness = (u8) backlight_get_brightness(bl);
+
+	ret = apple_smc_write_u16(smc_bl->smc, BACKLIGHT_BRIGHTNESS_KEY, smc_bl->brightness);
+	if (ret < 0)
+		return ret;
+
+	return 0;
+}
+
+static int macsmc_bl_get_brightness(struct backlight_device *bl)
+{
+	struct macsmc_bl *smc_bl = bl_get_data(bl);
+
+	return smc_bl->brightness;
+}
+
+static const struct backlight_ops macsmc_bl_ops = {
+	.options = BL_CORE_SUSPENDRESUME,
+	.get_brightness = macsmc_bl_get_brightness,
+	.update_status = macsmc_bl_update_status
+};
+
+static int macsmc_bl_probe(struct platform_device *pdev)
+{
+	struct macsmc_bl *smc_bl;
+	struct backlight_device *bl;
+	struct backlight_properties props;
+
+	smc_bl = devm_kzalloc(&pdev->dev, sizeof(*smc_bl), GFP_KERNEL);
+	if (!smc_bl)
+		return -ENOMEM;
+
+	smc_bl->smc = dev_get_drvdata(pdev->dev.parent);
+	if (!smc_bl->smc)
+		return -ENODEV;
+
+	if (!apple_smc_key_exists(smc_bl->smc,
+			BACKLIGHT_BRIGHTNESS_KEY))
+		return -ENODEV;
+	smc_bl->brightness = 0;
+
+	memset(&props, 0, sizeof(struct backlight_properties));
+	props.type = BACKLIGHT_PLATFORM;
+	props.scale = BACKLIGHT_SCALE_LINEAR;
+	props.max_brightness = 255;
+
+	bl = devm_backlight_device_register(&pdev->dev, pdev->name, &pdev->dev, smc_bl,
+			&macsmc_bl_ops, &props);
+	if (IS_ERR(bl))
+		return PTR_ERR(bl);
+
+	platform_set_drvdata(pdev, smc_bl);
+
+	return 0;
+}
+
+static struct platform_driver macsmc_bl_driver = {
+	.probe	= macsmc_bl_probe,
+	.driver	= {
+		.name = "macsmc-bl",
+	},
+};
+
+module_platform_driver(macsmc_bl_driver);
+
+MODULE_AUTHOR("Subu Dwevedi <messigoatcr7nop@gmail.com>");
+MODULE_DESCRIPTION("LED backlight driver for Intel-macs using macsmc");
+MODULE_LICENSE("Dual MIT/GPL");
+MODULE_ALIAS("platform:macsmc-bl");
