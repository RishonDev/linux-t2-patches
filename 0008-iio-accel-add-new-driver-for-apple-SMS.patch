diff --git a/drivers/iio/accel/macsmc-accel.c b/drivers/iio/accel/macsmc-accel.c
new file mode 100644
index 000000000000..cc0b8cc8b4c3
--- /dev/null
+++ b/drivers/iio/accel/macsmc-accel.c
@@ -0,0 +1,257 @@
+// SPDX-License-Identifier: GPL-2.0-only OR MIT
+/*
+ * Apple SMC Motion Sensor Driver
+ *
+ * Copyright (C) 2025 Subu Dwevedi <messigoatcr7nop@gmail.com>
+ */
+
+#include <linux/delay.h>
+#include <linux/iio/iio.h>
+#include <linux/input.h>
+#include <linux/mfd/macsmc.h>
+#include <linux/platform_device.h>
+#include <linux/pm.h>
+#include <linux/byteorder/generic.h>
+
+#define INIT_KEY SMC_KEY(MOCN)
+#define X_KEY	SMC_KEY(MO_X)
+#define Y_KEY	SMC_KEY(MO_Y)
+#define Z_KEY	SMC_KEY(MO_Z)
+#define MACSMC_ACCEL_CHANNEL(axis) {          \
+	.type = IIO_ACCEL,                    \
+	.modified = 1,                        \
+	.channel2 = IIO_MOD_##axis,           \
+	.info_mask_separate = BIT(IIO_CHAN_INFO_RAW), \
+}
+
+enum {
+	CALIBRATE = 1,
+};
+
+struct macsmc_accel {
+	struct apple_smc *smc;
+	s16 rest_x, rest_y;
+};
+
+static int macsmc_accel_read(struct macsmc_accel *drv, smc_key key, s16 *p)
+{
+	int ret;
+
+	ret = apple_smc_read_s16(drv->smc, key, p);
+	if (ret < 0)
+		return ret;
+
+	*p = cpu_to_be16(*p);
+	return 0;
+}
+
+static int macsmc_accel_dev_init(struct macsmc_accel *drv)
+{
+	int ret, total;
+	u16 buf;
+
+
+	for (total = 5000; total > 0; total -= 50) {
+		ret = apple_smc_read_u16(drv->smc, INIT_KEY, &buf);
+		if (!ret && buf)
+			return 0;
+
+		buf = 0xE0;
+		apple_smc_write_u16(drv->smc, INIT_KEY, buf);
+		msleep(50);
+	}
+
+	return -ENODEV;
+}
+
+static int macsmc_accel_calibrate(struct macsmc_accel *drv)
+{
+	int ret;
+
+	ret = macsmc_accel_read(drv, X_KEY, &drv->rest_x);
+	if (ret < 0)
+		return ret;
+
+	ret = macsmc_accel_read(drv, Y_KEY, &drv->rest_y);
+	if (ret < 0)
+		return ret;
+
+	drv->rest_x = -drv->rest_x;
+	return 0;
+}
+
+static void macsmc_accel_poll(struct input_dev *idev)
+{
+	struct macsmc_accel *drv = input_get_drvdata(idev);
+	int ret;
+	s16 x, y;
+
+	ret = macsmc_accel_read(drv, X_KEY, &x);
+	if (ret < 0)
+		return;
+
+	ret = macsmc_accel_read(drv, Y_KEY, &y);
+	if (ret < 0)
+		return;
+
+	x = -x;
+	input_report_abs(idev, ABS_X, x - drv->rest_x);
+	input_report_abs(idev, ABS_Y, y - drv->rest_y);
+	input_sync(idev);
+}
+
+static int macsmc_accel_read_raw(struct iio_dev *indio_dev, struct iio_chan_spec const *chan,
+		int *val, int *val2, long mask)
+{
+	struct macsmc_accel *drv = iio_priv(indio_dev);
+	int ret;
+	s16 buf;
+
+	if (mask != IIO_CHAN_INFO_RAW)
+		return -EINVAL;
+
+	if (chan->channel == CALIBRATE) {
+		*val = drv->rest_x;
+		*val2 = drv->rest_y;
+		return IIO_VAL_INT_MULTIPLE;
+	}
+
+	switch (chan->channel2) {
+	case IIO_MOD_X:
+		ret = macsmc_accel_read(drv, X_KEY, &buf);
+		if (ret < 0)
+			return ret;
+
+		*val = buf;
+		return IIO_VAL_INT;
+	case IIO_MOD_Y:
+		ret = macsmc_accel_read(drv, Y_KEY, &buf);
+		if (ret < 0)
+			return ret;
+
+		*val = buf;
+		return IIO_VAL_INT;
+	case IIO_MOD_Z:
+		ret = macsmc_accel_read(drv, Z_KEY, &buf);
+		if (ret < 0)
+			return ret;
+
+		*val = buf;
+		return IIO_VAL_INT;
+	}
+	return -EINVAL;
+}
+
+static int macsmc_accel_write_raw(struct iio_dev *indio_dev, struct iio_chan_spec const *chan,
+		int val, int val2, long mask)
+{
+	struct macsmc_accel *drv = iio_priv(indio_dev);
+
+	if (mask != IIO_CHAN_INFO_RAW || chan->channel != CALIBRATE)
+		return -EINVAL;
+
+	return macsmc_accel_calibrate(drv);
+}
+
+static const struct iio_chan_spec macsmc_accel_channels[] = {
+	MACSMC_ACCEL_CHANNEL(X),
+	MACSMC_ACCEL_CHANNEL(Y),
+	MACSMC_ACCEL_CHANNEL(Z),
+	{
+		.type = IIO_ACCEL,
+		.channel = CALIBRATE,
+		.info_mask_separate = BIT(IIO_CHAN_INFO_RAW),
+		.output = 1,
+		.indexed = 1,
+	}
+};
+
+static const struct iio_info macsmc_accel_info = {
+	.read_raw = macsmc_accel_read_raw,
+	.write_raw = macsmc_accel_write_raw,
+};
+
+static int macsmc_accel_restore(struct device *dev)
+{
+	struct macsmc_accel *drv = dev_get_drvdata(dev);
+
+	return macsmc_accel_dev_init(drv);
+}
+
+static const struct dev_pm_ops macsmc_accel_pm_ops = {
+	.restore = macsmc_accel_restore,
+};
+
+static int macsmc_accel_probe(struct platform_device *pdev)
+{
+	struct macsmc_accel *drv;
+	struct input_dev *idev;
+	struct iio_dev *indio;
+	int ret;
+
+	indio = devm_iio_device_alloc(&pdev->dev, sizeof(*drv));
+	if (!indio)
+		return -ENOMEM;
+
+	drv = iio_priv(indio);
+	drv->smc = dev_get_drvdata(pdev->dev.parent);
+	if (!drv->smc)
+		return -ENODEV;
+
+	if (!apple_smc_key_exists(drv->smc, INIT_KEY))
+		return -ENODEV;
+
+	ret = macsmc_accel_dev_init(drv);
+	if (ret < 0)
+		return ret;
+
+	ret = macsmc_accel_calibrate(drv);
+	if (ret < 0)
+		return ret;
+
+	indio->info = &macsmc_accel_info;
+	indio->channels = macsmc_accel_channels;
+	indio->num_channels = ARRAY_SIZE(macsmc_accel_channels);
+	indio->name = "macsmc-accel";
+	ret = iio_device_register(indio);
+	if (ret)
+		return ret;
+
+	idev = devm_input_allocate_device(&pdev->dev);
+	if (!idev)
+		return -ENOMEM;
+
+	idev->name = "macsmc-accel";
+	idev->id.bustype = BUS_HOST;
+	input_set_abs_params(idev, ABS_X, -256, 256, 4, 4);
+	input_set_abs_params(idev, ABS_Y, -256, 256, 4, 4);
+	input_set_drvdata(idev, drv);
+
+	ret = input_setup_polling(idev, macsmc_accel_poll);
+	if (ret)
+		return ret;
+
+	input_set_poll_interval(idev, 50);
+
+	ret = input_register_device(idev);
+	if (ret)
+		return ret;
+
+	platform_set_drvdata(pdev, drv);
+
+	return 0;
+}
+
+static struct platform_driver macsmc_accel_driver = {
+	.probe = macsmc_accel_probe,
+	.driver = {
+		.name = "macsmc-accel",
+		.pm = &macsmc_accel_pm_ops,
+	},
+};
+module_platform_driver(macsmc_accel_driver);
+
+MODULE_AUTHOR("Subu Dwevedi <messigoatcr7nop@gmail.com");
+MODULE_DESCRIPTION("Apple SMC Motion Sensor Driver");
+MODULE_LICENSE("Dual MIT/GPL");
+MODULE_ALIAS("platform:macsmc-accel");
-- 
